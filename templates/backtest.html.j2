{% extends "_layout.html.j2" %}
{% block content %}
<h2>6-month backtest</h2>
{% if not bt %}
<div class="empty">
  No backtest run yet. Trigger via:<br>
  <code style="background:var(--panel-2);padding:2px 6px;border-radius:3px;display:inline-block;margin-top:8px">gh workflow run backtester.yml --repo nishantgupta83/stock_app</code>
</div>
{% else %}
<p style="color:var(--muted);font-size:12px">
  Replayed {{ bt.days }} calendar days · {{ bt.signals_total }} hypothetical signals · model_version <code>{{ bt.model_version }}</code> · last run {{ bt.run_finished_at }}.
</p>

<div class="cards">
  <div class="card {% if bt.precision_at_5 >= 0.55 %}ok{% elif bt.precision_at_5 >= 0.50 %}warn{% else %}bad{% endif %}">
    <div class="label">Precision @ top 5/day</div>
    <div class="value">{{ "%.0f%%"|format(bt.precision_at_5 * 100) }}</div>
    <div class="sub">target ≥ 55% (§19)</div>
  </div>
  <div class="card {% if bt.brier <= 0.22 %}ok{% else %}warn{% endif %}">
    <div class="label">Pseudo-Brier (uncalibrated)</div>
    <div class="value">{{ "%.3f"|format(bt.brier) }}</div>
    <div class="sub">score/100 ≠ probability — relative use only</div>
  </div>
  <div class="card {% if bt.cal_error <= 0.10 %}ok{% else %}warn{% endif %}">
    <div class="label">Calibration error</div>
    <div class="value">{{ "%.1f%%"|format(bt.cal_error * 100) }}</div>
    <div class="sub">target ≤ 10%</div>
  </div>
  <div class="card {% if bt.sharpe >= 0.8 %}ok{% elif bt.sharpe > 0 %}warn{% else %}bad{% endif %}">
    <div class="label">Paper Sharpe</div>
    <div class="value">{{ "%.2f"|format(bt.sharpe) }}</div>
    <div class="sub">annualized · target > 0.8</div>
  </div>
  <div class="card {% if bt.max_dd <= 0.15 %}ok{% else %}bad{% endif %}">
    <div class="label">Max drawdown</div>
    <div class="value">{{ "%.1f%%"|format(bt.max_dd * 100) }}</div>
    <div class="sub">target ≤ 15%</div>
  </div>
  <div class="card">
    <div class="label">Direction accuracy</div>
    <div class="value">{{ "%.0f%%"|format(bt.dir_accuracy * 100) }}</div>
    <div class="sub">{{ bt.signals_total }} signals · 1-day horizon</div>
  </div>
</div>

<h3>Calibration curve (predicted prob vs realized hit rate)</h3>
{% if bt.calibration_buckets %}
<div class="calibration">
  {% for b in bt.calibration_buckets %}
  <div class="row">
    <div>{{ "%.0f%%"|format(b.bucket_lo * 100) }} – {{ "%.0f%%"|format(b.bucket_hi * 100) }}</div>
    <div class="bar">
      <div class="fill" style="width: {{ (b.actual_rate * 100)|round|int }}%"></div>
      <div class="marker" style="left: {{ ((b.bucket_lo + b.bucket_hi) / 2 * 100)|round|int }}%"></div>
    </div>
    <div>n={{ b.n }}</div>
  </div>
  {% endfor %}
</div>
<p style="color:var(--muted);font-size:11px;margin-top:8px">
  Bar = realized hit rate. Dashed marker = expected (perfectly calibrated would have bar reaching the marker).
</p>
{% endif %}

<h3>Top winners (highest realized return)</h3>
{% if bt.top_winners %}
<table>
  <thead><tr><th>Date</th><th>Ticker</th><th class="num">Score</th><th>Evidence</th><th class="num">Realized</th></tr></thead>
  <tbody>
  {% for r in bt.top_winners %}
    <tr>
      <td>{{ r.fired_at[:10] }}</td>
      <td><strong>{{ r.ticker }}</strong></td>
      <td class="num">{{ r.score|int }}</td>
      <td>{{ r.evidence_summary }}</td>
      <td class="num" style="color:var(--sage)">+{{ "%.2f%%"|format(r.realized_return * 100) }}</td>
    </tr>
  {% endfor %}
  </tbody>
</table>
{% endif %}

<h3>Top losers (most negative realized return)</h3>
{% if bt.top_losers %}
<table>
  <thead><tr><th>Date</th><th>Ticker</th><th class="num">Score</th><th>Evidence</th><th class="num">Realized</th></tr></thead>
  <tbody>
  {% for r in bt.top_losers %}
    <tr>
      <td>{{ r.fired_at[:10] }}</td>
      <td><strong>{{ r.ticker }}</strong></td>
      <td class="num">{{ r.score|int }}</td>
      <td>{{ r.evidence_summary }}</td>
      <td class="num" style="color:var(--coral)">{{ "%.2f%%"|format(r.realized_return * 100) }}</td>
    </tr>
  {% endfor %}
  </tbody>
</table>
{% endif %}

<div class="note">
  <strong>Honest caveats:</strong>
  Survivorship bias — universe is today's S&P leaders, not those from 6mo ago.
  Look-ahead bias controlled via next-day-open entry.
  Truth Social signal limited to last ~7 days (RSS history limit).
  0.05% slippage assumed each side, no commissions.
  6 months × 31 symbols is a small sample — calibration noisy.
</div>
{% endif %}
{% endblock %}
