{% extends "_layout.html.j2" %}
{% block content %}
<h2>Events stream</h2>
<p style="color:var(--muted);font-size:12px">Raw normalized events from every agent. Last 200, ordered by event time. Use this to verify what each agent is seeing.</p>

<div class="filters">
  <label>Type</label>
  <select id="f-type" onchange="render()">
    <option value="">all</option>
    {% for t in distinct_types %}<option>{{ t }}</option>{% endfor %}
  </select>
  <label>Ticker</label>
  <input id="f-ticker" type="text" placeholder="NVDA" oninput="render()" style="width:80px">
  <label>Min severity</label>
  <input id="f-sev" type="number" min="0" max="4" value="0" oninput="render()" style="width:60px">
  <span class="count" id="count">— rows</span>
</div>

<table>
  <thead>
    <tr>
      <th>Event time (UTC)</th>
      <th>Ticker</th>
      <th>Type</th>
      <th class="num">Sev</th>
      <th>Content / headline</th>
    </tr>
  </thead>
  <tbody id="rows"></tbody>
</table>
<div id="empty" class="empty" style="display:none">No events match.</div>

<script id="data" type="application/json">{{ events_json|tojson }}</script>
<script>
// HTML-escape — Trump post payloads contain raw HTML, must never reach innerHTML unescaped.
function esc(s) {
  if (s === null || s === undefined) return '';
  return String(s).replace(/[&<>"']/g, c => ({
    '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
  }[c]));
}
const DATA = JSON.parse(document.getElementById('data').textContent);
function render() {
  const fT = document.getElementById('f-type').value;
  const fTick = document.getElementById('f-ticker').value.trim().toUpperCase();
  const fSev = parseInt(document.getElementById('f-sev').value) || 0;
  const tbody = document.getElementById('rows');
  while (tbody.firstChild) tbody.removeChild(tbody.firstChild);
  let n = 0;
  for (const r of DATA) {
    if (fT && r.event_type !== fT) continue;
    if (fTick && (r.ticker || '').toUpperCase().indexOf(fTick) === -1) continue;
    if (r.severity < fSev) continue;
    n++;
    // Extract the most human-readable content from payload
    let content = '';
    const p = r.payload || {};
    if (r.event_type === 'news_article') {
      content = p.headline || p.url || '';
    } else if (r.event_type === 'truth_social_post') {
      content = p.post_excerpt || p.content_snippet || '';
    } else if (r.event_type === '8k_material_event') {
      const items = p['8k_items'] ? ' [items: ' + p['8k_items'] + ']' : '';
      content = (p.company_name || p.form_type || '8-K') + items;
    } else if (r.event_type && r.event_type.startsWith('filing_')) {
      content = p.form_type || r.event_type.replace('filing_', '').toUpperCase();
    } else {
      content = p.rule_label || r.event_subtype || '';
    }
    content = String(content).substring(0, 120);

    const tr = document.createElement('tr');
    // Build cells via DOM — no innerHTML with user content
    function cell(text, cls) {
      const td = document.createElement('td');
      if (cls) td.className = cls;
      td.textContent = text || '';
      return td;
    }
    tr.appendChild(cell((r.event_at || '').substring(0, 16)));
    const tickerTd = document.createElement('td');
    const b = document.createElement('strong');
    b.textContent = r.ticker || '—';
    tickerTd.appendChild(b);
    tr.appendChild(tickerTd);
    tr.appendChild(cell(r.event_type));
    tr.appendChild(cell(String(Number(r.severity) || 0), 'num'));
    tr.appendChild(cell(content));
    tbody.appendChild(tr);
  }
  document.getElementById('count').textContent = `${n} of ${DATA.length} rows`;
  document.getElementById('empty').style.display = n === 0 ? 'block' : 'none';
}
render();
</script>
{% endblock %}
