{% extends "_layout.html.j2" %}
{% block content %}
<h2>Calibration <span style="color:var(--muted);font-size:13px;font-weight:normal">— per-rule paper-trade accuracy. Mature rules (≥{{ maturity_acc_pct }}% with n≥{{ maturity_min_n }}) unlock BUY/SELL.</span></h2>

<div class="cards" style="margin-bottom:16px">
  <div class="card">
    <div class="label">Open paper trades</div>
    <div class="value">{{ open_paper_count }}</div>
    <div class="sub">opened by event_paper_agent, awaiting EOD reconcile</div>
  </div>
  <div class="card">
    <div class="label">Closed (last 30 days)</div>
    <div class="value">{{ closed_30d_count }}</div>
    <div class="sub">{% if closed_30d_count %}{{ "%.1f"|format(closed_30d_winrate * 100) }}% win rate · avg return {{ "%+.2f%%"|format(closed_30d_avg_ret * 100) }}{% else %}no closed trades yet{% endif %}</div>
  </div>
  <div class="card {% if mature_rules|length > 0 %}ok{% endif %}">
    <div class="label">Mature rules (BUY/SELL unlocked)</div>
    <div class="value">{{ mature_rules|length }}</div>
    <div class="sub">{% if mature_rules %}{{ mature_rules[:3]|join(", ") }}{% if mature_rules|length > 3 %}, …{% endif %}{% else %}none yet — keep accumulating data{% endif %}</div>
  </div>
  <div class="card">
    <div class="label">Total observations</div>
    <div class="value">{{ total_obs }}</div>
    <div class="sub">across {{ rule_rows|length }} distinct rules</div>
  </div>
</div>

<h3>Per-rule × horizon heatmap <span>top 20 by sample size</span></h3>
{% if heatmap_rows %}
<div class="heatmap" style="grid-template-columns: minmax(220px,1.5fr) repeat({{ horizons|length }}, 1fr);">
  <div class="h left">rule_key</div>
  {% for h in horizons %}<div class="h">h{{ h }}d</div>{% endfor %}
  {% for g in heatmap_rows %}
    <div class="c rule-name">
      <code>{{ g.base or g.rule_key }}</code>
      <span class="obs">n={{ g.total_obs }}</span>
    </div>
    {% for h in horizons %}
      {% set cell = g.horizons.get(h) %}
      {% if cell and cell.n_observations %}
        {% set acc = (cell.accuracy or 0) %}
        {% set band = 'green-3' if (acc >= 0.85 and cell.n_observations >= 20)
                      else 'green-2' if acc >= 0.75
                      else 'green-1' if acc >= 0.6
                      else 'amber-2' if (acc >= 0.5 and cell.n_observations >= 30)
                      else 'amber-1' if acc >= 0.4
                      else 'red-1' %}
        <div class="c {{ band }}">
          {% if cell.is_mature %}<span class="star">★</span>{% endif %}{{ '%.0f%%' | format(acc * 100) }}
          <div style="font-size:9px;opacity:0.7;margin-top:2px">n={{ cell.n_observations }}</div>
        </div>
      {% else %}
        <div class="c empty">—</div>
      {% endif %}
    {% endfor %}
  {% endfor %}
</div>
<p style="color:var(--muted);font-size:11px;font-family:var(--font-mono);margin-bottom:24px">★ = mature (n≥30, acc≥90%) · cell color = accuracy band</p>
{% endif %}

<h3>Per-rule accuracy</h3>
<p style="color:var(--muted);font-size:12px">A rule is one event_type[:event_subtype] combination. Sorted by absolute mean return × log(n+1), so a strong rule with many samples ranks above a marginal rule with few. Sample size column shaded green when n ≥ {{ maturity_min_n }}. <strong>Brier</strong> measures whether the rule's accuracy claim is well-calibrated against the last 30 days of outcomes (lower is better; floor is acc×(1−acc)). <strong>Drift</strong> is rolling-30d accuracy minus lifetime accuracy in pts — large negative drift means the rule is decaying.</p>

{% set drifting = rule_rows | selectattr("drift_pts", "ne", none) | rejectattr("drift_pts", "ge", -15) | list %}
{% if drifting | length > 0 %}
<div class="note" style="background:rgba(255,176,80,0.06);border-left:3px solid #ffb050;margin-bottom:12px">
  <strong>{{ drifting | length }} rule{{ "" if drifting|length == 1 else "s" }} showing drift ≥ 15 pts:</strong>
  rolling 30d accuracy materially below lifetime — possible regime break or sample-size artifact. See per-rule table below.
</div>
{% endif %}

<table>
  <thead>
    <tr>
      <th>Rule</th>
      <th class="num">N</th>
      <th class="num">Accuracy</th>
      <th class="num">Mean realized</th>
      <th class="num" title="Brier score over last 30d closed trades against rule's claimed accuracy. Lower is better; floor is acc×(1−acc).">Brier 30d</th>
      <th class="num" title="Rolling 30-day accuracy minus lifetime accuracy. Large gap = drift / regime break.">Drift</th>
      <th>Status</th>
      <th>Last updated</th>
    </tr>
  </thead>
  <tbody>
    {% for r in rule_rows %}
    {% set brier_floor = (r.accuracy or 0) * (1 - (r.accuracy or 0)) %}
    {% set brier_bad = r.brier_30d is not none and (r.brier_30d - brier_floor) > 0.08 %}
    <tr>
      <td><code>{{ r.rule_key }}</code></td>
      <td class="num" style="background:{% if r.n_observations >= maturity_min_n %}#163b2c{% else %}transparent{% endif %};color:{% if r.n_observations >= maturity_min_n %}#7adfb0{% else %}var(--muted){% endif %}">
        {{ r.n_observations }}
        {% if r.n_archived > 0 %}<small style="display:block;font-size:10px;color:var(--muted)">active {{ r.n_observations - r.n_archived }} / archived {{ r.n_archived }}</small>{% endif %}
      </td>
      <td class="num" style="color:{% if r.accuracy >= 0.7 %}var(--ok){% elif r.accuracy >= 0.5 %}var(--warn){% else %}var(--bad){% endif %}">
        {{ "%.1f%%"|format(r.accuracy * 100) }}
      </td>
      <td class="num" style="color:{% if r.mean_realized_pct and r.mean_realized_pct > 0 %}var(--ok){% elif r.mean_realized_pct and r.mean_realized_pct < 0 %}var(--bad){% else %}var(--muted){% endif %}">
        {% if r.mean_realized_pct is not none %}{{ "%+.2f%%"|format(r.mean_realized_pct * 100) }}{% else %}—{% endif %}
      </td>
      <td class="num" style="color:{% if r.brier_30d is none %}var(--muted){% elif brier_bad %}var(--bad){% else %}var(--ok){% endif %}" title="floor: {{ '%.3f' | format(brier_floor) }} · n_closed_30d: {{ r.n_closed_30d or 0 }}">
        {% if r.brier_30d is none %}—{% else %}{{ "%.3f"|format(r.brier_30d) }}{% endif %}
      </td>
      <td class="num" style="color:{% if r.drift_pts is none %}var(--muted){% elif r.drift_pts <= -15 %}var(--bad){% elif r.drift_pts >= 15 %}var(--ok){% else %}var(--muted){% endif %}">
        {% if r.drift_pts is none %}—{% else %}{{ "%+.0f"|format(r.drift_pts) }} pts{% endif %}
      </td>
      <td>
        {% if r.is_mature %}<span class="tag ok">MATURE · BUY/SELL allowed</span>
        {% elif r.n_observations < 10 %}<span class="tag" style="color:var(--muted)">needs data (n&lt;10)</span>
        {% else %}<span class="tag" style="color:var(--warn)">building</span>{% endif %}
      </td>
      <td style="font-size:12px;color:var(--muted)">{{ (r.last_updated or "")[:10] }}</td>
    </tr>
    {% else %}
    <tr><td colspan="8" class="empty">No calibration data yet. event_paper_agent runs hourly; price_agent reconciles weekday EOD. First closed trade should appear within 1 trading day.</td></tr>
    {% endfor %}
  </tbody>
</table>

<h3 style="margin-top:24px">Recently closed paper trades</h3>
<table>
  <thead>
    <tr>
      <th>Closed</th>
      <th>Ticker</th>
      <th>Direction</th>
      <th>Rule</th>
      <th class="num">Return</th>
      <th>Outcome</th>
    </tr>
  </thead>
  <tbody>
    {% for t in recent_closed %}
    <tr>
      <td style="font-size:12px">{{ (t.exit_at or "")[:16] }}</td>
      <td><strong><a href="ticker/{{ t.ticker }}.html" style="color:var(--ok)">{{ t.ticker }}</a></strong></td>
      <td><span class="tag {{ t.direction }}">{{ t.direction }}</span></td>
      <td style="font-size:12px"><code>{{ t.rule_key }}</code></td>
      <td class="num" style="color:{% if t.realized_return and t.realized_return > 0 %}var(--ok){% else %}var(--bad){% endif %}">
        {{ "%+.2f%%"|format((t.realized_return or 0) * 100) }}
      </td>
      <td style="text-align:center;font-size:18px">{% if t.correct %}✅{% else %}❌{% endif %}</td>
    </tr>
    {% else %}
    <tr><td colspan="6" class="empty">No closed paper trades yet.</td></tr>
    {% endfor %}
  </tbody>
</table>
{% endblock %}
