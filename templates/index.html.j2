{% extends "_layout.html.j2" %}
{% block content %}
<h2>Today at a glance</h2>

<div class="cards">
  <div class="card {% if alerts_today >= 5 %}warn{% else %}ok{% endif %}">
    <div class="label">Alerts sent today (UTC)</div>
    <div class="value">{{ alerts_today }} <span style="font-size:14px;color:var(--muted)">/ 5 cap</span></div>
    <div class="sub">{{ 5 - alerts_today }} remaining today</div>
  </div>
  <div class="card">
    <div class="label">Open candidates</div>
    <div class="value">{{ open_signals }}</div>
    <div class="sub">awaiting cluster confirmation or cap</div>
  </div>
  <div class="card">
    <div class="label">Fresh events (last 180m)</div>
    <div class="value">{{ fresh_events }}</div>
    <div class="sub">across all agents</div>
  </div>
  <div class="card {% if all_agents_healthy %}ok{% else %}bad{% endif %}">
    <div class="label">Agent health</div>
    <div class="value">{{ healthy_agent_count }} / {{ total_agent_count }}</div>
    <div class="sub">{% if all_agents_healthy %}all agents reporting{% else %}stale: {{ stale_agents|join(', ') }}{% endif %}</div>
  </div>
</div>

<h3>Recent live signals</h3>
{% if recent_signals %}
<table>
  <thead>
    <tr><th>Fired</th><th>Ticker</th><th>Action</th><th class="num">Score</th><th>Summary</th><th>Status</th></tr>
  </thead>
  <tbody>
    {% for s in recent_signals %}
    {% set action = s.display_action or s.action %}
    <tr>
      <td>{{ s.fired_at[:16] }}</td>
      <td><strong>{{ s.ticker }}</strong></td>
      <td><span class="tag {{ action }}">{{ action }}</span></td>
      <td class="num">
        {{ s.score|int }}
        <span class="score-bar"><span class="fill" style="width: {{ s.score_pct|round|int }}%"></span></span>
      </td>
      <td>{{ s.evidence_summary }}</td>
      <td><span class="tag {{ s.status_v2 }}">{{ s.status_v2 }}</span></td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<div class="empty">No live signals yet. Backtest rows are kept out of this dashboard summary so live paper review stays separate.</div>
{% endif %}

<h3>Building toward a signal <span style="color:var(--muted);font-size:13px;font-weight:normal">— past tracked events, last 5 days</span></h3>
{% if candidates %}
<table>
  <thead>
    <tr><th>Ticker</th><th>Sources</th><th>Events</th><th>Latest activity</th></tr>
  </thead>
  <tbody>
    {% for c in candidates %}
    <tr>
      <td><strong>
        {% if c.ticker in signal_tickers %}
          <a href="ticker/{{ c.ticker }}.html" style="color:var(--ok)">{{ c.ticker }}</a>
        {% else %}{{ c.ticker }}{% endif %}
      </strong></td>
      <td>
        {% for a in c.agents %}<span class="tag agent-{{ a }}">{{ a }}</span> {% endfor %}
        {% if c.agent_count >= 2 %}<span style="color:var(--ok);font-size:11px">✓ cluster ready</span>{% endif %}
      </td>
      <td class="num">{{ c.event_count }}</td>
      <td style="color:var(--muted);font-size:12px">{{ c.latest }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<div class="empty">No tickers accumulating evidence in the last 5 days.</div>
{% endif %}

<h3>Top recent events by agent</h3>
<div class="cards">
  {% for agent_name, n_recent, sample in agent_activity %}
  <div class="card">
    <div class="label"><span class="tag agent-{{ agent_name }}">{{ agent_name }}</span></div>
    <div class="value">{{ n_recent }}</div>
    <div class="sub">events in last 24h{% if sample %}<br>latest: {{ sample[:60] }}{% endif %}</div>
  </div>
  {% endfor %}
</div>

<div class="note">
  <strong>Reading guide:</strong> WATCH = ≥2 agents agree, score ≥70. RESEARCH = single strong signal. AVOID_CHASE = bearish or cautionary setup. CHASE_RISK = bullish setup where price already moved before the alert. All language is paper-only.
</div>
{% endblock %}
