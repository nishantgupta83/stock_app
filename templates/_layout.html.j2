<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta http-equiv="refresh" content="900">
  <meta name="git_sha" content="{{ git_sha | default('') }}">
  <meta name="generated_at" content="{{ generated_at | default('') }}">
  <title>{{ title }} · Hub4Apps Terminal</title>
  {% set rp = root_path | default("") %}
  <link rel="stylesheet" href="{{ rp }}styles.css">
</head>
<body>
{% if pin_hash %}
  <style>
    #h4a-pin-gate{position:fixed;inset:0;z-index:99999;background:#0d1117;
      display:flex;align-items:center;justify-content:center;
      font-family:-apple-system,BlinkMacSystemFont,'SF Mono',Menlo,monospace}
    #h4a-pin-gate .card{background:#161b22;border:1px solid #30363d;
      padding:30px 26px;border-radius:6px;min-width:260px;max-width:300px}
    #h4a-pin-gate h2{margin:0 0 16px;color:#e6edf3;font-size:13px;font-weight:500;
      letter-spacing:.05em;text-transform:uppercase}
    #h4a-pin-gate input{width:100%;padding:10px 12px;background:#0d1117;
      border:1px solid #30363d;border-radius:4px;color:#e6edf3;font-size:16px;
      font-family:inherit;box-sizing:border-box;outline:none;letter-spacing:.2em;
      text-align:center}
    #h4a-pin-gate input:focus{border-color:#2dd4bf}
    #h4a-pin-gate button{width:100%;margin-top:10px;padding:10px 12px;
      background:#2dd4bf;color:#0d1117;border:none;border-radius:4px;
      font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;
      letter-spacing:.06em;text-transform:uppercase}
    #h4a-pin-gate button:hover{background:#5eead4}
    #h4a-pin-gate .err{margin-top:10px;color:#f47174;font-size:11px;
      min-height:14px;text-align:center}
    body.h4a-unlocked #h4a-pin-gate{display:none}
    @keyframes h4a-shake{0%,100%{transform:translateX(0)}
      25%{transform:translateX(-5px)}75%{transform:translateX(5px)}}
    #h4a-pin-gate.shake .card{animation:h4a-shake .18s}
  </style>
  <script>
    /* Synchronous session check — runs before page content paints so a previously
       unlocked tab never shows the gate at all. */
    if (sessionStorage.getItem('h4a_pin_ok') === '1') {
      document.documentElement.addEventListener('DOMContentLoaded', function(){
        document.body.classList.add('h4a-unlocked');
      });
      /* If DOM is already past head (unlikely for inline at body start),
         apply immediately. */
      if (document.body) document.body.classList.add('h4a-unlocked');
    }
  </script>
  <div id="h4a-pin-gate" role="dialog" aria-modal="true">
    <form class="card" id="h4a-pin-form" autocomplete="off">
      <h2>Access</h2>
      <input type="password" id="h4a-pin-input" inputmode="numeric"
             pattern="[0-9]*" autofocus aria-label="PIN">
      <button type="submit">Enter</button>
      <div class="err" id="h4a-pin-err"></div>
    </form>
  </div>
  <script>
    /* PBKDF2-HMAC-SHA256 PIN verification. Same algorithm + salt + iterations
       as the server-side hash computed in site_generator.py — the browser
       just needs to reproduce the derivation to verify the user's input. */
    (function(){
      var HASH       = "{{ pin_hash }}";
      var SALT       = "{{ pin_salt }}";
      var ITERATIONS = {{ pin_iterations }};
      async function pbkdf2Hex(password){
        var enc = new TextEncoder();
        var baseKey = await crypto.subtle.importKey(
          'raw', enc.encode(password), 'PBKDF2', false, ['deriveBits']);
        var bits = await crypto.subtle.deriveBits({
          name: 'PBKDF2',
          salt: enc.encode(SALT),
          iterations: ITERATIONS,
          hash: 'SHA-256'
        }, baseKey, 256);
        return Array.from(new Uint8Array(bits)).map(function(b){
          return b.toString(16).padStart(2,'0');
        }).join('');
      }
      /* Constant-time string equality — defends against timing-leak attacks
         that could otherwise reveal how many leading hex chars match. Each
         iteration runs regardless of mismatches found. */
      function constantTimeEq(a, b){
        if (a.length !== b.length) return false;
        var d = 0;
        for (var i = 0; i < a.length; i++) {
          d |= a.charCodeAt(i) ^ b.charCodeAt(i);
        }
        return d === 0;
      }
      document.addEventListener('DOMContentLoaded', function(){
        var form  = document.getElementById('h4a-pin-form');
        var input = document.getElementById('h4a-pin-input');
        var btn   = form ? form.querySelector('button') : null;
        var gate  = document.getElementById('h4a-pin-gate');
        var err   = document.getElementById('h4a-pin-err');
        if (!form) return;
        form.addEventListener('submit', async function(e){
          e.preventDefault();
          err.textContent = '';
          /* PBKDF2-200k takes ~50-500ms depending on device — show a thinking
             state so the user doesn't think the page froze. */
          if (btn) { btn.disabled = true; btn.textContent = '…'; }
          try {
            var derived = await pbkdf2Hex(input.value);
            if (constantTimeEq(derived, HASH)) {
              sessionStorage.setItem('h4a_pin_ok','1');
              document.body.classList.add('h4a-unlocked');
              return;
            }
            gate.classList.add('shake');
            setTimeout(function(){ gate.classList.remove('shake'); }, 200);
            err.textContent = 'incorrect';
            input.value = '';
            input.focus();
          } finally {
            if (btn) { btn.disabled = false; btn.textContent = 'Enter'; }
          }
        });
      });
    })();
  </script>
{% endif %}
  <header>
    <div class="brand">
      <span class="logo">⌬</span>
      <h1>Hub4Apps <em>terminal</em></h1>
      <span class="subtitle">private · educational</span>
    </div>
    <nav>
      <a href="{{ rp }}index.html"        class="{% if active=='index' %}active{% endif %}">Dashboard</a>
      <a href="{{ rp }}signals.html"         class="{% if active=='signals' %}active{% endif %}">Signals</a>
      <a href="{{ rp }}events.html"          class="{% if active=='events' %}active{% endif %}">Events</a>
      <a href="{{ rp }}trade_setups.html"    class="{% if active=='trade_setups' %}active{% endif %}">Setups</a>
      <a href="{{ rp }}risk_decisions.html"  class="{% if active=='risk_decisions' %}active{% endif %}">Risk</a>
      <a href="{{ rp }}agents.html"          class="{% if active=='agents' %}active{% endif %}">Agents</a>
      <a href="{{ rp }}backtest.html"        class="{% if active=='backtest' %}active{% endif %}">Backtest</a>
      <a href="{{ rp }}paper_trades.html"    class="{% if active=='paper_trades' %}active{% endif %}">Paper</a>
      <a href="{{ rp }}calibration.html"     class="{% if active=='calibration' %}active{% endif %}">Calibration</a>
      <a href="{{ rp }}weekly.html"          class="{% if active=='weekly' %}active{% endif %}">Weekly</a>
      <a href="{{ rp }}learning.html"        class="{% if active=='learning' %}active{% endif %}">Learning</a>
    </nav>
    <div class="meta">
      <div>session</div>
      <div>{{ generated_at }} utc</div>
    </div>
  </header>
  <main>
    {% block content %}{% endblock %}
  </main>
  <footer>
    <p><strong>Vocabulary</strong> · WATCH · RESEARCH · AVOID_CHASE · CHASE_RISK paper-only until rule maturity (≥90% accuracy with n≥30) unlocks BUY / SELL.</p>
    <p><strong>Stack</strong> · SEC EDGAR · trumpstruth.org RSS · FRED · FDA · DoD · NRC · clinicaltrials.gov · TSA · yfinance.  GitHub Actions + Supabase Free + Hostinger static.  Not financial advice.</p>
  </footer>
</body>
</html>
