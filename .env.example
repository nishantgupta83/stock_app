# Copy to .env and fill in. Never commit .env.
# In GitHub Actions these are stored as repo secrets, not in this file.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_KEY=eyJ...        # service_role key, server-side only

TELEGRAM_BOT_TOKEN=123456:ABC...   # from @BotFather
TELEGRAM_CHAT_ID=987654321         # your numeric Telegram chat id

# EDGAR requires a User-Agent identifying you (per SEC fair-access policy)
EDGAR_USER_AGENT=Nishant Gupta nishugupta@gmail.com

# Optional, used in later phases
FINNHUB_API_KEY=
FRED_API_KEY=
