.env
.env.local
*.pyc
__pycache__/
.venv/
venv/
.DS_Store
dist/*.html
dist/alert/*.html
*.log
.ops_run_id_*
.idea/
.vscode/
.claude/
*.bak
# Supabase CLI workspace — contains project ref + pooler connection string in .temp/.
# We track migrations in sql/ rather than supabase/migrations/, so the whole folder is safe to ignore.
supabase/

# One-off generated audit / review documents that aren't part of the operational stack.
security_best_practices_report.md

# Local offline-regrade snapshots (closed trades + price bars) — see
# scripts/snapshot_paper_trades.py. Re-fetchable; do not commit the data.
regrade_data*/

# Local Paper Book ledger + dashboard (SQLite + HTML) — local-only, off-Supabase.
# Ignore the whole directory contents but re-include the three files that the
# paper_book workflow commits back (book_state.json, metrics.json, dashboard.html).
# Must use paper_book/* (contents form), NOT paper_book/ (dir form), because git
# refuses to un-ignore files inside a directory-ignored path.
paper_book/*
!paper_book/book_state.json
!paper_book/metrics.json
!paper_book/dashboard.html
